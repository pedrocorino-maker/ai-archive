APP_ENV=local
AUTH_MODE=attach_cdp

# Chrome CDP (attach_cdp mode)
CHROME_CDP_URL=http://127.0.0.1:9222

# Chrome profile (managed_profile mode)
CHROME_USER_DATA_DIR=./data/state/chrome_profile
CHROME_CHANNEL=chrome

# Storage state (reuse authenticated sessions)
STORAGE_STATE_PATH=./data/state/storage_state.json

# Google Drive (OAuth Desktop App)
GOOGLE_DRIVE_CREDENTIALS_JSON=./credentials.json
GOOGLE_DRIVE_TOKEN_JSON=./token.json
GOOGLE_DRIVE_RAW_FOLDER_ID=
GOOGLE_DRIVE_CURATED_FOLDER_ID=

# Optional credentials — NOT used by default. Login is always manual.
OPTIONAL_CHATGPT_EMAIL=
OPTIONAL_CHATGPT_PASSWORD=
OPTIONAL_GOOGLE_EMAIL=
OPTIONAL_GOOGLE_PASSWORD=

# Embeddings
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
TOPIC_SIMILARITY_THRESHOLD=0.82

# Optional LLM refinement (set to none to disable)
CURATION_LLM_PROVIDER=none
CURATION_LLM_MODEL=
CURATION_LLM_API_KEY=

# Crawl limits
MAX_CONVERSATIONS_PER_RUN=

# Browser behavior
INTERACTIVE=true
SLOW_MO_MS=150
JITTER_MIN_MS=600
JITTER_MAX_MS=1400
